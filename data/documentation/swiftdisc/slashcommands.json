{"metadata":{"modules":[{"name":"SwiftDisc"}],"images":[{"type":"card","identifier":"swiftdisc-logo.svg"}],"roleHeading":"Article","role":"article","title":"Slash Commands"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftDisc\/documentation\/SwiftDisc\/SlashCommands"},"sections":[],"abstract":[{"text":"Register and handle slash commands with typed option accessors.","type":"text"}],"variants":[{"paths":["\/documentation\/swiftdisc\/slashcommands"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SwiftDisc\/documentation\/SwiftDisc"]]},"primaryContentSections":[{"content":[{"level":2,"text":"Basic Example","anchor":"Basic-Example","type":"heading"},{"syntax":"swift","code":["import Foundation","import SwiftDisc","","@main","struct SlashBot {","    static func main() async {","        let token = ProcessInfo.processInfo.environment[\"DISCORD_BOT_TOKEN\"] ?? \"\"","        let client = DiscordClient(token: token)","","        let slash = SlashCommandRouter()","        await slash.register(\"ping\") { ctx in","            try await ctx.client.createInteractionResponse(","                interactionId: ctx.interaction.id,","                token: ctx.interaction.token,","                content: \"Pong!\"","            )","        }","","        await client.useSlashCommands(slash)","        try? await client.loginAndConnect(intents: [.guilds])","        let events = await client.events","        for await _ in events { }","    }","}"],"type":"codeListing"},{"level":2,"text":"Command Options","anchor":"Command-Options","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Add options to commands with fluent builders:","type":"text"}]},{"syntax":"swift","code":["await slash.register(\"greet\") { ctx in","    let name = try ctx.option(\"name\")","    try await ctx.client.createInteractionResponse(","        interactionId: ctx.interaction.id,","        token: ctx.interaction.token,","        content: \"Hello, \\(name)!\"","