{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftDisc\/documentation\/SwiftDisc\/GettingStarted"},"sections":[],"metadata":{"role":"article","title":"Getting Started","images":[{"type":"card","identifier":"swiftdisc-logo.svg"}],"modules":[{"name":"SwiftDisc"}],"roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/SwiftDisc\/documentation\/SwiftDisc"]]},"primaryContentSections":[{"kind":"content","content":[{"text":"1. Create a SwiftPM project","type":"heading","level":2,"anchor":"1-Create-a-SwiftPM-project"},{"code":["\/\/ swift-tools-version: 6.2","import PackageDescription","","let package = Package(","    name: \"MyBot\",","    platforms: [.macOS(.v11)],","    dependencies: [","        .package(url: \"https:\/\/github.com\/M1tsumi\/SwiftDisc.git\", from: \"2.4.0\")","    ],","    targets: [","        .executableTarget(","            name: \"MyBot\",","            dependencies: [\"SwiftDisc\"]","        )","    ]",")"],"type":"codeListing","syntax":"swift"},{"text":"2. Write your bot","type":"heading","level":2,"anchor":"2-Write-your-bot"},{"inlineContent":[{"text":"Create a ","type":"text"},{"code":"main.swift","type":"codeVoice"},{"text":" file:","type":"text"}],"type":"paragraph"},{"code":["import Foundation","import SwiftDisc","","@main","struct MyBot {","    static func main() async {","        let token = ProcessInfo.processInfo.environment[\"DISCORD_BOT_TOKEN\"] ?? \"\"","        let client = DiscordClient(token: token)","","        await client.setOnReady { ready in","            print(\"Logged in as \\(ready.user.username)\")","        }","","        await client.setOnMessage { message in","            guard message.content?.lowercased() == \"ping\" else { return }","            try await message.reply(client: client, content: \"Pong!\")","        }","","        do {","            try await client.loginAndConnect(intents: [.guilds, .guildMessages, .messageContent])","            let events = await client.events","            for await _ in events { }","        } catch {","            print(\"Client failed: \\(error)\")","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"text":"3. Run","type":"heading","level":2,"anchor":"3-Run"},{"code":["export DISCORD_BOT_TOKEN=\"your_token_here\"","swift run"],"type":"codeListing","syntax":"bash"},{"text":"Next steps","type":"heading","level":2,"anchor":"Next-steps"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Learn about "},{"type":"reference","identifier":"doc:\/\/SwiftDisc\/documentation\/SwiftDisc\/EventHandling","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Add ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftDisc\/documentation\/SwiftDisc\/SlashCommands","type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Explore "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftDisc\/documentation\/SwiftDisc\/DiscordClient"},{"type":"text","text":" for the full API"}]}]}]}]}],"abstract":[{"text":"Create a bot, connect to Discord, and send your first message.","type":"text"}],"variants":[{"paths":["\/documentation\/swiftdisc\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","references":{"swiftdisc-logo.svg":{"identifier":"swiftdisc-logo.svg","alt":null,"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/SwiftDisc\/swiftdisc-logo.svg"}]},"doc://SwiftDisc/documentation/SwiftDisc/SlashCommands":{"kind":"article","abstract":[{"text":"Register and handle slash commands with typed option accessors.","type":"text"}],"type":"topic","identifier":"doc:\/\/SwiftDisc\/documentation\/SwiftDisc\/SlashCommands","images":[{"identifier":"swiftdisc-logo.svg","type":"card"}],"title":"Slash Commands","url":"\/documentation\/swiftdisc\/slashcommands","role":"article"},"doc://SwiftDisc/documentation/SwiftDisc/EventHandling":{