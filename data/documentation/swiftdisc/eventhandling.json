{"kind":"article","sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"SwiftDisc gives you two ways to handle gateway events: callbacks and async streams.","type":"text"}],"metadata":{"role":"article","title":"Event Handling","roleHeading":"Article","images":[{"type":"card","identifier":"swiftdisc-logo.svg"}],"modules":[{"name":"SwiftDisc"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftdisc\/eventhandling"]}],"primaryContentSections":[{"content":[{"text":"Callbacks","type":"heading","anchor":"Callbacks","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set individual callbacks for the events you care about:"}]},{"syntax":"swift","type":"codeListing","code":["await client.setOnReady { ready in","    print(\"Bot is ready in \\(ready.guilds.count) guilds\")","}","","await client.setOnMessage { message in","    guard message.content == \"ping\" else { return }","    try await message.reply(client: client, content: \"Pong!\")","}","","await client.setOnGuildCreate { guild in","    print(\"Joined \\(guild.name), \\(guild.member_count ?? 0) members\")","}"]},{"type":"paragraph","inlineContent":[{"text":"Available callbacks include: ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftDisc\/documentation\/SwiftDisc\/DiscordClient\/onReady","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftDisc\/documentation\/SwiftDisc\/DiscordClient\/onMessage","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftDisc\/documentation\/SwiftDisc\/DiscordClient\/onMessageUpdate","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftDisc\/documentation\/SwiftDisc\/DiscordClient\/onGuildCreate","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftDisc\/documentation\/SwiftDisc\/DiscordClient\/onInteractionCreate","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftDisc\/documentation\/SwiftDisc\/DiscordClient\/onReactionAdd","type":"reference"},{"text":", ","type":"text"},{"code":"DiscordClient\/onMemberAdd","type":"codeVoice"},{"text":", and 30+ more — one for every Discord gateway event.","type":"text"}]},{"text":"Async Stream","type":"heading","anchor":"Async-Stream","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you need to filter, combine, or transform events, use the unified stream:"}]},{"syntax":"swift","type":"codeListing","code":["for await event in await client.events {","    switch event {","    case .messageCreate(let msg) where msg.content == \"ping\":","        try await msg.reply(client: client, content: \"Pong!\")","    case .guildCreate(let guild):","        print(\"New guild: \\(guild.name)\")","    case .reactionAdd(let reaction):","        guard reaction.emoji.name == \"⭐\" else { break }","        print(\"Starred in channel \\(reaction.channel_id)\")","    default:","        break","    }","}"]},{"text":"Connection State","type":"heading","anchor":"Connection-State","level":2},{"type":"paragraph","inlineContent":[{"text":"Monitor the Gateway connection state in real time:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["for await state in await client.connectionState {","    switch state {","    case .ready:         print(\"Connected and ready\")","    case .reconnecting:  print(\"Reconnecting...\")","    case .resuming:      print(\"Resuming session\")","    case .disconnected:  print(\"Disconnected\")","    case .connecting:    print(\"Connecting...\")","    case .identifying:   print(\"Identifying...\")","    }","}"]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/SwiftDisc\/documentation\/SwiftDisc"]]},"identifier":{"url":"doc:\/\/SwiftDisc\/documentation\/SwiftDisc\/EventHandling","interfaceLanguage":"swift"},"references":{"doc://SwiftDisc/documentation/SwiftDisc/DiscordClient/onMessage